<!-- Custom Wazuh Rules for ZTNA Lab -->
<!-- Location on Wazuh Manager: /var/ossec/etc/rules/local_rules.xml -->
<!-- Author: Rahul Rajkumar Kori -->

<!-- Default SSH rule -->
<group name="local,syslog,sshd,">
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>
</group>

<!-- OpenZiti ZTNA Authentication Rules -->
<!--
  These rules detect failed JWT authentication attempts against the
  OpenZiti Controller. The controller logs these events when an invalid
  or expired JWT is presented for identity-based network access.

  Rule 100200: Single failure (Level 10 - High)
    Fires when OpenZiti rejects a JWT token during authentication.
    Indicates either an expired token, invalid signature, or
    unauthorized access attempt.

  Rule 100201: Multiple failures (Level 12 - Critical)
    Fires when 3+ JWT failures occur within 120 seconds.
    Indicates a brute force attack against the ZTNA control plane.
    This is a correlation rule — it watches for repeated 100200 events.
-->
<group name="openziti,ztna,">
  <rule id="100200" level="10">
    <match>none of which were valid for primary authentication</match>
    <description>OpenZiti: Failed JWT authentication attempt - possible unauthorized access</description>
    <group>authentication_failed,ztna_auth_failure,</group>
  </rule>

  <rule id="100201" level="12" frequency="3" timeframe="120">
    <if_matched_sid>100200</if_matched_sid>
    <description>OpenZiti: Multiple failed JWT authentications - possible attack</description>
    <group>authentication_failures,ztna_bruteforce,</group>
  </rule>
</group>
